# AvenEditor environment template
# Copy to .env and adjust values for your environment.

# Optional: server listen port.
# `npm run dev` defaults to 3000 (UI+API together).
# `npm run dev:server` defaults to 8787 unless PORT is set.
PORT=""

# Optional: docker-compose published port (host -> container 3000).
AVENEDITOR_HTTP_PORT="3000"

# Optional: docker-compose host path mounted to container `/workspace`.
# Use absolute path in production, e.g. "/srv/aveneditor-workspace".
AVENEDITOR_WORKSPACE_HOST_PATH="./workspace"

# Optional: enable Vite HMR in fullstack dev (`npm run dev`).
# Default is false to avoid full-page reload when editing workspace files.
AVENEDITOR_DEV_HMR="false"

# Required for server API authentication (MVP secure key check).
AVENEDITOR_ACCESS_KEY="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Optional: limit user-provided workspaces to this root directory.
# Example:
# AVENEDITOR_WORKSPACE_ROOT="/srv/workspaces"
AVENEDITOR_WORKSPACE_ROOT=""

# Optional: session lifetime in seconds (default 7d = 604800).
# Also controls how long refresh-persisted login stays valid.
AVENEDITOR_SESSION_TTL_SECONDS="604800"

# Optional: max entries returned from workspace tree (default 5000).
AVENEDITOR_MAX_TREE_ENTRIES="5000"

# Optional: path/name of a .gitignore-style ignore file (default ".avenignore").
# Relative paths are resolved from the selected workspace root.
# This file is merged with AVENEDITOR_IGNORE_DIRS.
# Supports patterns like: node_modules/, build/, *.log, etc.
# Example: AVENEDITOR_IGNORE_FILE="/app/.avenignore"
AVENEDITOR_IGNORE_FILE=".avenignore"

# Optional: comma-separated ignore entries for workspace scan.
# Entries can be directory names, file names, or glob patterns.
# Always merged with AVENEDITOR_IGNORE_FILE rules.
# Example: node_modules,.git,dist,index.html,*.log
AVENEDITOR_IGNORE_DIRS="node_modules,.git,dist"

# Optional: max file size allowed for read API, bytes (default 1MB).
AVENEDITOR_MAX_FILE_SIZE_BYTES="1048576"

# Optional: CORS allow origin for API. Use exact origin in production.
# Example: AVENEDITOR_ALLOW_ORIGIN="https://editor.example.com"
AVENEDITOR_ALLOW_ORIGIN="*"

# Optional: save per-write diff history files under workspace/.history.
AVENEDITOR_HISTORY_ENABLED="true"
AVENEDITOR_HISTORY_DIR=".history"

# Optional: enable read-only mode to prevent all write operations (create, update, delete).
# Default is true for safety. Set to false to allow modifications.
AVENEDITOR_READ_ONLY="true"
